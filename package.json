{
  "name": "yatagarasu",
  "version": "0.1.0",
  "description": "Local dev dashboard to monitor Claude Code agents in real time",
  "license": "MIT",
  "author": "masa5228",
  "keywords": [
    "claude-code",
    "claude",
    "dashboard",
    "agents",
    "monitoring",
    "hooks",
    "cli"
  ],
  "homepage": "https://github.com/masa5228/yatagarasu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masa5228/yatagarasu.git"
  },
  "bugs": {
    "url": "https://github.com/masa5228/yatagarasu/issues"
  },
  "bin": {
    "yata": "./dist/bin/yata.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client \"tsx watch src/server/dev.ts\" \"vite\"",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/bin/yata.js start",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
